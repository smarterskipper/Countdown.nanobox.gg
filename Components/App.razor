<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Countdown to August 5th</title>

    <!-- Open Graph -->
    <meta property="og:title" content="Countdown to August 5th" />
    <meta property="og:description" content="A living countdown with daily AI-generated art themed around world holidays." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#0f0f1a" />

    <!-- MudBlazor -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["HomelabCountdown.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />

    <!-- Blazor reconnect modal — styled to match dark theme -->
    <div id="components-reconnect-modal">
        <div class="reconnect-content">
            <div class="reconnect-icon">⟳</div>
            <p class="reconnect-msg reconnect-show-msg">Reconnecting…</p>
            <p class="reconnect-msg reconnect-failed-msg">
                Connection lost.
                <a href="" onclick="window.Blazor.reconnect()">Try again</a>
            </p>
            <p class="reconnect-msg reconnect-rejected-msg">
                Session expired. <a href="">Reload</a>
            </p>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="app.js"></script>
</body>

</html>
