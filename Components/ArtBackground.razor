@* Isolated background component — ShouldRender blocks per-second clock re-renders
   so the video element is never patched by Blazor and plays uninterrupted. *@
@inject IJSRuntime JS

@if (!string.IsNullOrEmpty(VideoUrl))
{
    <video @ref="_videoRef" class="art-bg-video" autoplay loop muted playsinline>
        <source src="@VideoUrl" type="video/mp4">
    </video>
}
else
{
    <div class="art-bg" style="@BgStyle"></div>
}

@code {
    [Parameter] public string? VideoUrl  { get; set; }
    [Parameter] public string? BgStyle   { get; set; }

    private ElementReference _videoRef;
    private string? _renderedVideoUrl;
    private string? _renderedBgStyle;

    protected override bool ShouldRender()
    {
        if (VideoUrl != _renderedVideoUrl)
        {
            _renderedVideoUrl = VideoUrl;
            _renderedBgStyle  = BgStyle;
            return true;
        }
        // Only re-render for BgStyle when no video is playing — BgStyle changes
        // (e.g. gradient → image URL as art loads) must not recreate the video element
        if (string.IsNullOrEmpty(VideoUrl) && BgStyle != _renderedBgStyle)
        {
            _renderedBgStyle = BgStyle;
            return true;
        }
        return false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(VideoUrl))
        {
            // Set slow playback and ensure play() is called — oncanplay HTML attribute
            // is unreliable on first load and 0.05 is below Chrome's minimum rate (~0.063)
            await JS.InvokeVoidAsync("eval",
                "var v = document.querySelector('video.art-bg-video'); if(v){ v.playbackRate=0.15; v.play().catch(()=>{}); }");
        }
    }
}
