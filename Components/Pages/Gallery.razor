@page "/gallery"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ArtCacheService ArtCache
@inject ViewerDbService ViewerDb
@inject PhotoService Photos
@implements IDisposable

<PageTitle>Art Gallery · Countdown to August 5th</PageTitle>

<div class="gallery-page">

    <!-- Header -->
    <div class="gallery-header">
        <a href="/" class="gallery-back">← Back</a>
        <h1 class="gallery-title">Daily Art Gallery</h1>
        <p class="gallery-subtitle">Each piece generated by Claude, themed around a place in Utah</p>
    </div>

    <!-- Timelapse player -->
    <div class="timelapse-bar">
        <button class="timelapse-toggle" @onclick="ToggleTimelapse">
            @(_timelapseOpen ? "✕ Close Timelapse" : "▶ Play Timelapse")
        </button>
        @if (!_timelapseOpen)
        {
            <span class="timelapse-hint">@_timelapseArts.Count day@(_timelapseArts.Count == 1 ? "" : "s") captured</span>
        }
    </div>

    @if (_timelapseOpen && _timelapseArts.Count > 0)
    {
        var frame = _timelapseArts[_timelapseIndex];
        <div class="timelapse-player">
            <div class="timelapse-frame">
                <img src="@frame.ScreenshotUrl" alt="@frame.PlaceName" />
                <div class="timelapse-frame-overlay">
                    <span class="timelapse-frame-date">@frame.Date.ToString("MMMM d, yyyy")</span>
                    <span class="timelapse-frame-holiday">@frame.PlaceName · @frame.WeatherSummary</span>
                    <span class="timelapse-frame-counter">@(_timelapseIndex + 1) / @_timelapseArts.Count</span>
                </div>
            </div>
            <div class="timelapse-controls">
                <button class="timelapse-btn" title="Previous"
                        @onclick="() => { StopTimelapse(); _timelapseIndex = Math.Max(0, _timelapseIndex - 1); }">⏮</button>
                <button class="timelapse-btn timelapse-btn--play" @onclick="TogglePlay">
                    @(_timelapsePlaying ? "⏸" : "▶")
                </button>
                <button class="timelapse-btn" title="Next"
                        @onclick="() => { StopTimelapse(); _timelapseIndex = Math.Min(_timelapseArts.Count - 1, _timelapseIndex + 1); }">⏭</button>
                <input type="range" class="timelapse-scrubber"
                       min="0" max="@(_timelapseArts.Count - 1)"
                       value="@_timelapseIndex"
                       @oninput="ScrubTimelapse" />
                <select class="timelapse-speed" @onchange="e => ChangeSpeed(e.Value?.ToString())">
                    <option value="3000">Slow</option>
                    <option value="1500" selected>Normal</option>
                    <option value="600">Fast</option>
                    <option value="200">Very fast</option>
                </select>
            </div>
        </div>
    }

    <!-- Grid -->
    @if (_allArt.Count == 0)
    {
        <div class="gallery-empty">
            <MudText Typo="Typo.h5" Color="Color.Default" Class="mt-8 text-center">
                No art pieces yet — check back tomorrow!
            </MudText>
        </div>
    }
    else
    {
        <div class="gallery-grid">
            @foreach (var art in _allArt)
            {
                var views = _viewsByDate.GetValueOrDefault(art.Date, 0);
                var photoCount = _photoCountsByDate.GetValueOrDefault(art.Date, 0);
                <div class="gallery-card @(_selected == art ? "gallery-card--active" : "")"
                     @onclick="() => SelectArt(art)"
                     style="--primary: @art.PrimaryColor; --accent: @art.AccentColor;">
                    <div class="gallery-card-img">
                        <img src="@art.ScreenshotUrl" alt="@art.PlaceName"
                             loading="lazy" />
                        @if (photoCount > 0)
                        {
                            <span class="gallery-card-photo-badge">📷 @photoCount</span>
                        }
                    </div>
                    <div class="gallery-card-info">
                        <div class="gallery-card-date">@art.Date.ToString("MMM d, yyyy")</div>
                        <div class="gallery-card-holiday">@art.PlaceName</div>
                        <div class="gallery-card-meta">
                            <span>@art.WeatherSummary</span>
                            <span class="gallery-card-views">
                                @if (views > 0)
                                { <span>👁 @views</span> }
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Detail modal -->
    @if (_selected is not null)
    {
        var modalViews = _viewsByDate.GetValueOrDefault(_selected.Date, 0);
        <div class="gallery-modal-backdrop" @onclick="CloseDetail">
            <div class="gallery-modal" @onclick:stopPropagation>
                <button class="gallery-modal-close" @onclick="CloseDetail">✕</button>
                <img src="@_selected.ScreenshotUrl" alt="@_selected.PlaceName" class="gallery-modal-img" />
                <div class="gallery-modal-body">
                    <h2>@_selected.PlaceName</h2>
                    <p class="gallery-modal-country">@_selected.PlaceDescription · @_selected.Date.ToString("MMMM d, yyyy")</p>
                    @if (!string.IsNullOrEmpty(_selected.WeatherSummary))
                    {
                        <p class="gallery-modal-country">@_selected.WeatherSummary</p>
                    }
                    <p class="gallery-modal-theme">Theme: @_selected.Theme</p>
                    <p class="gallery-modal-stats">
                        Score: @_selected.FinalScore.ToString("F1")/10 ·
                        @_selected.AttemptCount attempt@(_selected.AttemptCount == 1 ? "" : "s") ·
                        Generated @_selected.GeneratedAt.ToString("HH:mm UTC")
                        @if (modalViews > 0) { <span> · 👁 @modalViews views</span> }
                    </p>
                    @if (_modalViewers.Count > 0)
                    {
                        <div class="gallery-modal-viewers">
                            @foreach (var v in _modalViewers)
                            {
                                <span class="gallery-modal-viewer-chip" title="@(v.StateName ?? v.CountryName)">
                                    <img src="@FlagUrl(v)"
                                         alt="@(v.StateCode ?? v.CountryCode)"
                                         onerror="@($"this.onerror=null;this.src='https://flagcdn.com/w20/{v.CountryCode.ToLower()}.png'")"
                                         style="width:14px;height:10px;object-fit:cover;border-radius:2px;" />
                                    @(v.StateCode ?? v.CountryCode) ×@v.Count
                                </span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_selected.FinalCritique))
                    {
                        <p class="gallery-modal-critique">Claude's notes: "@_selected.FinalCritique"</p>
                    }

                    <!-- ── Personal photos scrapbook ── -->
                    <div class="gallery-photos-section">
                        <div class="gallery-photos-header">
                            <span class="gallery-photos-title">📷 Memories</span>
                            <label class="gallery-upload-btn @(_uploading ? "gallery-upload-btn--loading" : "")">
                                @(_uploading ? "Uploading…" : "+ Add photo")
                                <InputFile OnChange="HandlePhotoUpload" accept="image/*" multiple disabled="@_uploading" style="display:none" />
                            </label>
                        </div>
                        @if (_modalPhotos.Count > 0)
                        {
                            <div class="gallery-photos-grid">
                                @foreach (var url in _modalPhotos)
                                {
                                    var capturedUrl = url;
                                    <div class="gallery-photo-thumb" @onclick="() => OpenPhoto(capturedUrl)">
                                        <img src="@capturedUrl" alt="memory" loading="lazy" />
                                        <button class="gallery-photo-delete"
                                                @onclick="() => DeletePhoto(capturedUrl)"
                                                @onclick:stopPropagation>✕</button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="gallery-photos-empty">No memories yet — add some photos from this day.</p>
                        }
                    </div>

                    <a class="gallery-modal-view-btn"
                       href="/?date=@_selected.Date.ToString("yyyy-MM-dd")">
                        View Full Art →
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Photo lightbox -->
    @if (_lightboxUrl is not null)
    {
        <div class="gallery-lightbox" @onclick="() => _lightboxUrl = null">
            <img src="@_lightboxUrl" alt="memory" @onclick:stopPropagation />
            <button class="gallery-lightbox-close" @onclick="() => _lightboxUrl = null">✕</button>
        </div>
    }
</div>

@code {
    private List<DailyArt> _allArt = [];
    private DailyArt? _selected;
    private Dictionary<DateOnly, int> _viewsByDate = new();
    private Dictionary<DateOnly, int> _photoCountsByDate = new();
    private List<ViewerEntry> _modalViewers = [];
    private List<string> _modalPhotos = [];
    private bool _uploading;
    private string? _lightboxUrl;

    // Timelapse
    private List<DailyArt> _timelapseArts = [];
    private bool _timelapseOpen;
    private bool _timelapsePlaying;
    private int _timelapseIndex;
    private int _timelapseSpeedMs = 1500;
    private CancellationTokenSource? _timelapseCts;

    protected override async Task OnInitializedAsync()
    {
        _allArt = ArtCache.GetAllCachedArt();
        _viewsByDate = await ViewerDb.GetTotalViewsByDateAsync();
        _photoCountsByDate = Photos.GetPhotoCountsByDate();
        _timelapseArts = _allArt.OrderBy(a => a.Date).ToList();
    }

    private async Task SelectArt(DailyArt art)
    {
        _selected = art;
        _lightboxUrl = null;
        _modalViewers = await ViewerDb.GetViewersForDateAsync(art.Date);
        _modalPhotos = Photos.GetPhotosForDate(art.Date);
    }

    private void CloseDetail()
    {
        _selected = null;
        _modalViewers = [];
        _modalPhotos = [];
        _lightboxUrl = null;
    }

    private async Task HandlePhotoUpload(InputFileChangeEventArgs e)
    {
        if (_selected is null) return;
        _uploading = true;
        foreach (var file in e.GetMultipleFiles(20))
        {
            var url = await Photos.SavePhotoAsync(_selected.Date, file);
            if (url is not null)
                _modalPhotos.Add(url);
        }
        _photoCountsByDate = Photos.GetPhotoCountsByDate();
        _uploading = false;
    }

    private void DeletePhoto(string url)
    {
        if (_selected is null) return;
        Photos.DeletePhoto(_selected.Date, url);
        _modalPhotos.Remove(url);
        _photoCountsByDate = Photos.GetPhotoCountsByDate();
    }

    private void OpenPhoto(string url) => _lightboxUrl = url;

    private static string FlagUrl(ViewerEntry v) =>
        v.CountryCode == "US" && v.StateCode is not null
            ? $"https://flagcdn.com/w20/us-{v.StateCode.ToLower()}.png"
            : $"https://flagcdn.com/w20/{v.CountryCode.ToLower()}.png";

    // ── Timelapse ─────────────────────────────────────────────────────────────

    private void ScrubTimelapse(ChangeEventArgs e)
    {
        StopTimelapse();
        if (int.TryParse(e.Value?.ToString(), out var idx))
            _timelapseIndex = idx;
    }

    private void ToggleTimelapse()
    {
        _timelapseOpen = !_timelapseOpen;
        if (!_timelapseOpen) StopTimelapse();
    }

    private async Task TogglePlay()
    {
        if (_timelapsePlaying) StopTimelapse();
        else await StartTimelapseAsync();
    }

    private async Task StartTimelapseAsync()
    {
        if (_timelapseArts.Count == 0) return;
        _timelapsePlaying = true;
        _timelapseCts = new CancellationTokenSource();
        var token = _timelapseCts.Token;
        var speed = _timelapseSpeedMs;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(speed));
            try
            {
                while (_timelapsePlaying && await timer.WaitForNextTickAsync(token))
                {
                    await InvokeAsync(() =>
                    {
                        if (_timelapseIndex >= _timelapseArts.Count - 1)
                        {
                            _timelapsePlaying = false;
                            _timelapseCts?.Cancel();
                        }
                        else
                        {
                            _timelapseIndex++;
                        }
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private void StopTimelapse()
    {
        _timelapsePlaying = false;
        _timelapseCts?.Cancel();
        _timelapseCts?.Dispose();
        _timelapseCts = null;
    }

    private async Task ChangeSpeed(string? val)
    {
        if (int.TryParse(val, out var ms)) _timelapseSpeedMs = ms;
        if (_timelapsePlaying)
        {
            StopTimelapse();
            await StartTimelapseAsync();
        }
    }

    public void Dispose()
    {
        StopTimelapse();
    }
}
