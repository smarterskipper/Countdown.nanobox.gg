@page "/"
@rendermode InteractiveServer
@inject ArtCacheService ArtCache
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Countdown to August 5th</PageTitle>

<!-- ── Full-screen SVG art background ── -->
<div class="art-bg" style="@ArtBgStyle">
    @if (_svgContent is not null)
    {
        @((MarkupString)_svgContent)
    }
    else
    {
        <!-- fallback gradient while generating -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 600" width="100%" height="100%">
            <defs>
                <linearGradient id="fbg" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#0f0f1a"/>
                    <stop offset="100%" stop-color="#1a1a3e"/>
                </linearGradient>
            </defs>
            <rect width="900" height="600" fill="url(#fbg)"/>
        </svg>
    }
</div>

<!-- ── Dark overlay scrim ── -->
<div class="scrim"></div>

<!-- ── Top nav bar ── -->
<div class="topbar">
    <span class="topbar-brand">✦ homelab</span>
    <div class="topbar-links">
        <a href="/gallery" class="topbar-link">Gallery</a>
        <button class="topbar-link btn-link" @onclick="ToggleWindowSwap">
            @(_showWindowSwap ? "✕ Close window" : "🪟 Watch a window")
        </button>
    </div>
</div>

<!-- ── Main countdown card ── -->
<div class="countdown-center">

    @if (_art is null)
    {
        <div class="countdown-card loading-card">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <p class="loading-text">Generating today's art with Claude…</p>
        </div>
    }
    else
    {
        <div class="countdown-card">
            <!-- Holiday banner -->
            <div class="holiday-banner" style="border-color: @(_art.AccentColor)55; background: @(_art.PrimaryColor)18;">
                <span class="holiday-banner-flag">@GetFlag(_art.CountryCode)</span>
                <div class="holiday-banner-text">
                    <div class="holiday-banner-name" style="color: @_art.AccentColor;">@_art.HolidayName</div>
                    <div class="holiday-banner-country">@_art.CountryName · @_art.Date.ToString("MMMM d")</div>
                </div>
            </div>

            <!-- Days number -->
            <div class="days-number" style="color: @_art.AccentColor; text-shadow: 0 0 40px @(_art.AccentColor)88;">
                @_daysRemaining
            </div>
            <div class="days-label">days until August 5th</div>

            <!-- Progress bar -->
            <div class="progress-track">
                <div class="progress-fill"
                     style="width: @(_progressPercent.ToString("F1"))%;
                            background: linear-gradient(90deg, @_art.PrimaryColor, @_art.SecondaryColor);">
                </div>
            </div>
            <div class="progress-label">
                @_progressPercent.ToString("F0")% of the journey
            </div>

            <!-- Art attribution -->
            <div class="art-credit">
                Art by Claude · score @_art.FinalScore.ToString("F1")/10 · @_art.Theme
            </div>
        </div>
    }
</div>

<!-- ── WindowSwap picture-in-picture ── -->
@if (_showWindowSwap)
{
    <div class="windowswap-pip">
        <div class="pip-titlebar">
            <span>🪟 somewhere in the world</span>
            <button class="pip-close" @onclick="ToggleWindowSwap">✕</button>
        </div>
        <iframe src="/api/windowswap"
                title="WindowSwap"
                sandbox="allow-scripts allow-same-origin allow-forms"
                loading="lazy">
        </iframe>
    </div>
}

@code {
    private static readonly DateOnly Target = new(2026, 8, 5);
    private static readonly DateOnly CountdownStart = new(2026, 1, 1);

    private DailyArt? _art;
    private string? _svgContent;
    private int _daysRemaining;
    private double _progressPercent;
    private bool _showWindowSwap;

    protected override void OnInitialized()
    {
        ArtCache.OnArtGenerated += HandleArtGenerated;
        LoadArt();
        CalculateCountdown();
    }

    private void LoadArt()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _art = ArtCache.GetArtForDate(today);
        if (_art is not null)
            _svgContent = ArtCache.ReadSvgContent(today);
    }

    private void HandleArtGenerated(DailyArt art)
    {
        if (art.Date != DateOnly.FromDateTime(DateTime.Today)) return;
        InvokeAsync(() =>
        {
            _art = art;
            _svgContent = ArtCache.ReadSvgContent(art.Date);
            StateHasChanged();
        });
    }

    private void CalculateCountdown()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _daysRemaining = Math.Max(0, Target.DayNumber - today.DayNumber);

        var totalDays = Target.DayNumber - CountdownStart.DayNumber;
        var elapsed = today.DayNumber - CountdownStart.DayNumber;
        _progressPercent = totalDays > 0
            ? Math.Min(100, Math.Max(0, (double)elapsed / totalDays * 100))
            : 100;
    }

    private void ToggleWindowSwap() => _showWindowSwap = !_showWindowSwap;

    private string ArtBgStyle => _art is null
        ? "background: linear-gradient(135deg, #0f0f1a 0%, #1a1a3e 100%);"
        : "";

    private static string GetFlag(string countryCode) => countryCode.Length != 2 ? "🌍" :
        string.Concat(countryCode.ToUpperInvariant().Select(c => char.ConvertFromUtf32(c + 0x1F1A5)));

    public void Dispose() => ArtCache.OnArtGenerated -= HandleArtGenerated;
}
