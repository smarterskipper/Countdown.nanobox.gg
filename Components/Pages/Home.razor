@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ArtCacheService ArtCache
@inject WeatherService Weather
@inject NavigationManager Nav
@inject ViewerTrackingService ViewerTracker
@inject ViewerDbService ViewerDb
@inject GenerationStatusService GenStatus
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Countdown to August 5th</PageTitle>

<!-- ── Full-screen art background (static fallback; video injected via JS) ── -->
<div class="art-bg" style="@ArtBgStyle"></div>

<!-- ── April 1st special day overlay ── -->
@if (_isSpecialDay)
{
    <div class="special-day-overlay">
        @for (int i = 0; i < 24; i++)
        {
            <span class="special-heart" style="@HeartStyle(i)">★</span>
        }
        <div class="special-day-message">
            <div class="special-day-title">Today's the Day ★</div>
            <div class="special-day-sub">Go enjoy every moment</div>
        </div>
    </div>
}

<!-- ── Weather particle overlay ── -->
@if (_weather is not null)
{
    <div class="weather-overlay weather-@_weather.Type" style="--weather-color: @_weather.Color;">
        @for (int i = 0; i < _particles.Count; i++)
        {
            var p = _particles[i];
            <div class="weather-particle" style="@p"></div>
        }
    </div>
}

<!-- ── Milestone overlay (fires on milestone days) ── -->
@if (_activeMilestone.HasValue && !_isHistorical && !_milestoneDismissed)
{
    <div class="milestone-overlay milestone-overlay--@MilestoneSize(_activeMilestone.Value)"
         @onclick="() => _milestoneDismissed = true">
        @for (int i = 0; i < 28; i++)
        {
            <span class="milestone-star" style="@MilestoneStarStyle(i)">★</span>
        }
        <div class="milestone-content">
            <div class="milestone-eyebrow">milestone reached</div>
            <div class="milestone-number" style="@MilestoneNumberStyle(_activeMilestone.Value)">@_activeMilestone</div>
            <div class="milestone-label">days remaining</div>
            <div class="milestone-title">@MilestoneTitle(_activeMilestone.Value)</div>
            <div class="milestone-dismiss">tap to continue</div>
        </div>
    </div>
}

<!-- ── Top nav bar ── -->
<div class="topbar" style="@(_art is not null ? $"border-bottom-color: {_art.PrimaryColor}30;" : "")">
    @if (_isHistorical)
    {
        <a href="/" class="topbar-back">← Today</a>
        <span class="topbar-date">@_viewingDate.ToString("MMMM d, yyyy")</span>
    }
    else
    {
        <span class="topbar-brand">✦ CountDown</span>
    }
    <div class="topbar-links">
        <a href="/gallery" class="topbar-link">Gallery</a>
        <a href="/about" class="topbar-link">About</a>
        <a href="/auth/logout" class="topbar-link" style="opacity:0.4;font-size:0.75rem;">Sign out</a>
    </div>
</div>

<!-- ── Main countdown card ── -->
<div class="countdown-center">
    <div class="countdown-card">
        <!-- Milestone overlay badge (shown when on a milestone day) -->
        @if (_activeMilestone.HasValue)
        {
            <div class="milestone-badge-wrap">
                <span class="milestone-badge">@MilestoneBadgeLabel(_activeMilestone.Value)</span>
            </div>
        }

        <!-- Days number — shown immediately, themed once art loads -->
        <div class="days-number" style="@DaysNumberStyle">
            @_daysRemaining
        </div>

        <!-- Progress bar -->
        <div class="progress-wrapper" style="--pct: @_progressPercent.ToString("F2")">
            <div class="progress-track" style="@ProgressTrackStyle">
                <div class="progress-fill"
                     style="width: @(_progressPercent.ToString("F1"))%;
                            @ProgressFillStyle">
                    <div class="progress-heat"></div>
                    <div class="progress-heat" style="animation-delay:-1.1s;animation-duration:2.6s;opacity:.75;"></div>
                    <div class="progress-heat" style="animation-delay:-0.5s;animation-duration:1.9s;opacity:.5;"></div>
                </div>
            </div>
        </div>
        <div class="bottom-card">
            <div class="progress-label">
                @_progressPercent.ToString("F0")% of the journey
            </div>

            <!-- Live clock (hours : minutes : seconds) -->
            @if (!_isHistorical)
            {
                <div class="clock-display">@_timeStr</div>
                <div class="date-weather-line">
                    <span class="date-weather-date">@DateTime.UtcNow.AddMinutes(-_clientTzOffset).ToString("dddd, MMMM d")</span>
                    @if (_weather is not null)
                    {
                        <span class="date-weather-sep">·</span>
                        <span class="date-weather-condition">@WeatherIcon(_weather.Type) @_weather.Description</span>
                    }
                </div>
            }

            <!-- Art attribution / generating state -->
            @if (_art is null)
            {
                @if (!_isHistorical && _genProgress is not null)
                {
                    <div class="gen-status">
                        <div class="gen-status-phase">@_genProgress.Phase</div>
                        @if (_genProgress.MaxAttempts > 0)
                        {
                            <div class="gen-status-bar">
                                <div class="gen-status-fill" style="width:@((double)_genProgress.Attempt / _genProgress.MaxAttempts * 100)%"></div>
                            </div>
                            @if (_genProgress.LastScore.HasValue)
                            {
                                <div class="gen-status-score">last score @_genProgress.LastScore.Value.ToString("F1")/10</div>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="art-credit generating">@(_isHistorical ? "no art for this day" : "generating today's art…")</div>
                }
            }
            else
            {
                <div class="art-credit">@_art.Theme</div>
            }
        </div>

        <!-- April 1st mini countdown -->
        @if (_daysUntilSpecial > 0)
        {
            <div class="special-mini-countdown">
                <span class="smc-heart">★</span>
                <span class="smc-text">@_daysUntilSpecial day@(_daysUntilSpecial == 1 ? "" : "s")</span>
            </div>
        }

        <!-- Approaching milestone teaser -->
        @if (_approachingMilestone.HasValue && !_isHistorical)
        {
            var daysAway = _daysRemaining - _approachingMilestone.Value;
            <div class="milestone-approaching milestone-approaching--@MilestoneSize(_approachingMilestone.Value) @(daysAway <= 2 ? "milestone-approaching--urgent" : "")">
                <span>🎯</span>
                <span>@daysAway day@(daysAway == 1 ? "" : "s") until @_approachingMilestone day mark</span>
            </div>
        }
    </div>
</div>

<!-- ── Viewer sidebar ── -->
<div class="viewer-sidebar">
    <div class="viewer-header">
        <span class="viewer-eye">👁</span>
        <span class="viewer-title">@(_isHistorical ? _viewingDate.ToString("MMM d") : "Today")</span>
        <span class="viewer-total">@_totalViews</span>
    </div>
    <div class="viewer-list">
        @if (_viewers.Count == 0)
        {
            <div class="viewer-empty">No visitors yet</div>
        }
        else
        {
            @foreach (var v in _viewers)
            {
                <div class="viewer-row" title="@(v.StateName ?? v.CountryName)">
                    <img class="viewer-flag"
                         src="@FlagUrl(v)"
                         alt="@(v.StateCode ?? v.CountryCode)"
                         onerror="@($"this.onerror=null;this.src='https://flagcdn.com/w20/{v.CountryCode.ToLower()}.png'")" />
                    <span class="viewer-loc">
                        @if (v.StateCode is not null)
                        { @v.StateCode }
                        else
                        { @(v.CountryName.Length > 12 ? v.CountryCode : v.CountryName) }
                    </span>
                    <span class="viewer-count">@v.Count</span>
                </div>
            }
        }
    </div>
</div>

@code {
    private static readonly DateOnly Target = new(2026, 8, 5);
    private static readonly DateOnly CountdownStart = new(2024, 2, 5);
    private static readonly DateOnly SpecialDate = new(2026, 4, 1);
    private static readonly int[] Milestones = [500, 365, 300, 200, 100, 75, 50, 25, 10, 5, 3, 2, 1, 0];

    private int _daysUntilSpecial;
    private bool _isSpecialDay;

    // Milestones
    private int? _activeMilestone;
    private int? _approachingMilestone;
    private bool _milestoneDismissed;

    // Live clock
    private string _timeStr = "00:00:00";
    private CancellationTokenSource? _clockCts;

    // Client timezone: JS getTimezoneOffset() = minutes UTC is ahead of local (positive = behind UTC)
    private int _clientTzOffset = 0; // default to UTC until JS responds

    [Parameter, SupplyParameterFromQuery(Name = "date")]
    public string? DateParam { get; set; }

    private DateOnly _viewingDate;
    private bool _isHistorical;

    private GenerationProgress? _genProgress;

    private DailyArt? _art;
    private WeatherEffect? _weather;
    private List<string> _particles = [];
    private int _daysRemaining;
    private double _progressPercent;

    private List<ViewerEntry> _viewers = [];
    private int _totalViews;

    protected override void OnInitialized()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _viewingDate = DateParam is not null && DateOnly.TryParse(DateParam, out var parsed)
            ? parsed
            : today;
        _isHistorical = _viewingDate != today;

        // Only subscribe to live events when viewing today
        if (!_isHistorical)
        {
            ArtCache.OnArtGenerated += HandleArtGenerated;
            ViewerTracker.OnViewersUpdated += HandleViewersUpdated;
            GenStatus.OnChanged += HandleGenStatusChanged;
            _genProgress = GenStatus.Current;

            // Show whatever is already in the cache (non-blocking)
            var (viewers, total) = ViewerTracker.GetCached();
            _viewers = viewers;
            _totalViews = total;
        }

        LoadArt();
        LoadWeather();
        CalculateCountdown();
    }

    protected override async Task OnInitializedAsync()
    {
        if (_isHistorical)
        {
            // Load historical viewer data from DB
            var viewers = await ViewerDb.GetViewersForDateAsync(_viewingDate);
            _viewers = viewers;
            _totalViews = viewers.Sum(v => v.Count);
        }
        else
        {
            // Load fresh from DB on first render
            var (viewers, total) = await ViewerTracker.LoadTodayAsync();
            _viewers = viewers;
            _totalViews = total;
        }
    }

    private void HandleViewersUpdated()
    {
        InvokeAsync(() =>
        {
            var (viewers, total) = ViewerTracker.GetCached();
            _viewers = viewers;
            _totalViews = total;
            StateHasChanged();
        });
    }

    private void LoadArt()
    {
        _art = ArtCache.GetArtForDate(_viewingDate);
    }

    private void LoadWeather()
    {
        _weather = ArtCache.GetWeatherForDate(_viewingDate);
        if (_weather is not null)
            _particles = BuildParticles(_weather);
    }

    private void HandleArtGenerated(DailyArt art)
    {
        if (art.Date != _viewingDate) return;
        InvokeAsync(() =>
        {
            _art = art;
            if (_weather is null) LoadWeather();
            StateHasChanged();
        });
    }

    private void CalculateCountdown()
    {
        _daysRemaining = Math.Max(0, Target.DayNumber - _viewingDate.DayNumber);

        var totalDays = Target.DayNumber - CountdownStart.DayNumber;
        var elapsed = _viewingDate.DayNumber - CountdownStart.DayNumber;
        _progressPercent = totalDays > 0
            ? Math.Min(100, Math.Max(0, (double)elapsed / totalDays * 100))
            : 100;

        // Special date (April 1st) — only shown when viewing today
        if (!_isHistorical)
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            _isSpecialDay = today == SpecialDate;
            _daysUntilSpecial = Math.Max(0, SpecialDate.DayNumber - today.DayNumber);
            if (_isSpecialDay) _daysUntilSpecial = 0;

            // Milestones
            _activeMilestone = Milestones.Contains(_daysRemaining) ? _daysRemaining : null;
            _approachingMilestone = null;
            if (_activeMilestone is null)
            {
                var next = Milestones.Where(m => m < _daysRemaining).OrderByDescending(m => m).FirstOrDefault(-1);
                if (next >= 0 && _daysRemaining - next <= 7)
                    _approachingMilestone = next;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mount/unmount video outside Blazor's render cycle so the clock timer can't reset it
        if (_art?.HasVideo == true)
            await JS.InvokeVoidAsync("artVideo.mount", _art.VideoUrl);
        else
            await JS.InvokeVoidAsync("artVideo.unmount");

        if (firstRender && !_isHistorical)
        {
            // Get the viewer's local timezone offset from the browser
            _clientTzOffset = await JS.InvokeAsync<int>("eval", "new Date().getTimezoneOffset()");

            // Recalculate days using client's local date
            var clientToday = DateOnly.FromDateTime(DateTime.UtcNow.AddMinutes(-_clientTzOffset));
            _daysRemaining = Math.Max(0, Target.DayNumber - clientToday.DayNumber);
            var totalDays = Target.DayNumber - CountdownStart.DayNumber;
            var elapsed = clientToday.DayNumber - CountdownStart.DayNumber;
            _progressPercent = totalDays > 0
                ? Math.Min(100, Math.Max(0, (double)elapsed / totalDays * 100))
                : 100;

            _clockCts = new CancellationTokenSource();
            _ = RunClockAsync(_clockCts.Token);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunClockAsync(CancellationToken ct)
    {
        UpdateClock();
        await InvokeAsync(StateHasChanged);
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                UpdateClock();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void UpdateClock()
    {
        // Target = midnight Aug 5 2026 in the viewer's local timezone, expressed as UTC
        // getTimezoneOffset() = (UTC - local) in minutes, so midnight local = midnight UTC + offset minutes
        var targetUtc = new DateTime(2026, 8, 5, 0, 0, 0, DateTimeKind.Utc).AddMinutes(_clientTzOffset);
        var remaining = targetUtc - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero) { _timeStr = "00:00:00"; return; }
        var h = (int)remaining.TotalHours % 24;
        _timeStr = $"{h:D2}:{remaining.Minutes:D2}:{remaining.Seconds:D2}";
    }

    private static string HeartStyle(int i)
    {
        var rng = new Random(i * 31 + 7);
        var left = rng.Next(2, 98);
        var delay = rng.Next(0, 6000);
        var dur = rng.Next(4000, 9000);
        var size = rng.Next(14, 32);
        return $"left:{left}%;animation-delay:{delay}ms;animation-duration:{dur}ms;font-size:{size}px;";
    }

    private static List<string> BuildParticles(WeatherEffect w)
    {
        var rng = new Random(w.Date.DayNumber);
        var particles = new List<string>();
        int count = w.Type switch
        {
            "rain" or "storm" => 30,
            "snow" => 20,
            "sun" or "heat" => 12,
            "aurora" => 10,
            _ => 15
        };

        for (int i = 0; i < count; i++)
        {
            var left = rng.Next(0, 100);
            var delay = rng.Next(0, 4000);
            var dur = w.Type switch
            {
                "rain" or "storm" => rng.Next(400, 900),
                "snow" => rng.Next(3000, 8000),
                "aurora" => rng.Next(6000, 14000),
                _ => rng.Next(2000, 6000)
            };
            var size = w.Type switch
            {
                "rain" or "storm" => $"width:1px;height:{rng.Next(12,22)}px",
                "snow" => $"width:{rng.Next(3,7)}px;height:{rng.Next(3,7)}px",
                "sun" => $"width:{rng.Next(2,5)}px;height:{rng.Next(2,5)}px",
                "aurora" => $"width:{rng.Next(80,200)}px;height:{rng.Next(2,5)}px",
                _ => $"width:{rng.Next(4,10)}px;height:{rng.Next(4,10)}px"
            };
            var top = w.Type == "aurora" ? rng.Next(5, 40) : -10;
            particles.Add($"left:{left}%;top:{top}%;{size};animation-delay:{delay}ms;animation-duration:{dur}ms");
        }
        return particles;
    }

    private static string SparkStyle(int i)
    {
        var rng      = new Random(i * 17 + 3);
        var delay    = rng.Next(0, 2000);
        var duration = rng.Next(350, 900);
        var driftX   = rng.Next(-30, 31);       // wide sideways arc
        var driftY   = rng.Next(-14, 28);       // mostly downward, some go up
        var w        = rng.Next(2, 5);          // spark width
        var h        = rng.Next(5, 16);         // elongated — looks like a streak
        var colours  = new[] { "#ffffff", "#fffacc", "#ffee66", "#ffcc22", "#ff9900" };
        var colour   = colours[rng.Next(colours.Length)];
        return $"--delay:{delay}ms;--dur:{duration}ms;--dx:{driftX}px;--dy:{driftY}px;--w:{w}px;--h:{h}px;--col:{colour};";
    }

    // flagcdn.com supports ISO 3166-2 subdivision codes for US states
    private static string FlagUrl(ViewerEntry v) =>
        v.CountryCode == "US" && v.StateCode is not null
            ? $"https://flagcdn.com/w20/us-{v.StateCode.ToLower()}.png"
            : $"https://flagcdn.com/w20/{v.CountryCode.ToLower()}.png";

    private static string WeatherIcon(string type) => type switch
    {
        "sun"   => "☀️",
        "heat"  => "🌡️",
        "rain"  => "🌧️",
        "snow"  => "❄️",
        "storm" => "⛈️",
        "fog"   => "🌫️",
        "wind"  => "💨",
        "aurora"=> "🌌",
        _       => "⛅"
    };

    private string ArtBgStyle => _art is null
        ? "background: linear-gradient(135deg, #0f0f1a 0%, #1a1a3e 100%);"
        : $"background-image: url('{_art.ScreenshotUrl}'); background-size: cover; background-position: center;";

    private string DaysNumberStyle => _art is null
        ? "color: rgba(255,255,255,0.85); text-shadow: 0 2px 20px rgba(0,0,0,0.9);"
        : $"color: {_art.AccentColor}; text-shadow: 0 2px 20px rgba(0,0,0,0.9), 0 0 80px {_art.AccentColor}66;";

    private string ProgressTrackStyle => _art is null
        ? ""
        : $"background: {_art.PrimaryColor}22;";

    // Heat overlay sits on top of the solid art color — transparent on the left,
    // burning orange→white only on the rightmost ~30% near the tip.
    private string ProgressFillStyle => _art is null
        ? "background-color: rgba(255,255,255,0.35); background-image: linear-gradient(90deg, transparent 60%, rgba(255,130,0,0.65) 82%, rgba(255,220,80,0.95) 94%, #ffffff 100%);"
        : $"background-color: {_art.PrimaryColor}; background-image: linear-gradient(90deg, transparent 55%, rgba(255,110,0,0.6) 80%, rgba(255,220,70,0.95) 93%, #ffffff 100%); box-shadow: 0 0 8px {_art.PrimaryColor}66;";

    // ── Milestone helpers ─────────────────────────────────────────────────────

    private static string MilestoneSize(int days) => days switch
    {
        0 or 1       => "fire",
        <= 5         => "urgent",
        <= 25        => "close",
        <= 100       => "big",
        _            => "major"
    };

    private static string MilestoneBadgeLabel(int days) => days switch
    {
        0   => "🎉 THE DAY IS HERE",
        1   => "⚡ TOMORROW",
        <= 5 => $"🔥 {days} DAYS",
        365 => "📅 ONE YEAR",
        500 => "🌟 500 DAYS",
        _   => $"✦ {days} DAY MARK"
    };

    private static string MilestoneTitle(int days) => days switch
    {
        0   => "August 5th is here.",
        1   => "One more sleep.",
        2   => "Two days left.",
        3   => "Three days to go.",
        5   => "Five days remaining.",
        10  => "Ten days out.",
        25  => "Twenty-five days.",
        50  => "Fifty days remaining.",
        75  => "Seventy-five days left.",
        100 => "One hundred days to go.",
        200 => "Two hundred days.",
        300 => "Three hundred days.",
        365 => "One year remaining.",
        500 => "Five hundred days.",
        _   => $"{days} days remaining."
    };

    private static string MilestoneNumberStyle(int days) => days switch
    {
        0 or 1   => "color:#fbbf24; text-shadow: 0 0 60px #fbbf2488, 0 0 120px #f59e0b44;",
        <= 5     => "color:#f97316; text-shadow: 0 0 60px #f9731688;",
        <= 25    => "color:#a78bfa; text-shadow: 0 0 60px #a78bfa88;",
        <= 100   => "color:#60a5fa; text-shadow: 0 0 60px #60a5fa88;",
        _        => "color:#34d399; text-shadow: 0 0 60px #34d39988;"
    };

    private static string MilestoneStarStyle(int i)
    {
        var rng   = new Random(i * 37 + 13);
        var left  = rng.Next(2, 98);
        var delay = rng.Next(0, 5000);
        var dur   = rng.Next(3000, 9000);
        var size  = rng.Next(10, 28);
        var top   = rng.Next(5, 90);
        return $"left:{left}%;top:{top}%;animation-delay:{delay}ms;animation-duration:{dur}ms;font-size:{size}px;";
    }

    private void HandleGenStatusChanged(GenerationProgress? progress)
    {
        InvokeAsync(() =>
        {
            _genProgress = progress;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _clockCts?.Cancel();
        _clockCts?.Dispose();
        ArtCache.OnArtGenerated -= HandleArtGenerated;
        ViewerTracker.OnViewersUpdated -= HandleViewersUpdated;
        GenStatus.OnChanged -= HandleGenStatusChanged;
    }
}
