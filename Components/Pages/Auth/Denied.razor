@page "/auth/denied"
@layout HomelabCountdown.Components.Layout.MainLayout

<PageTitle>Access Denied · Countdown</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">✦ CountDown</div>
        <h1 class="auth-title" style="color: rgba(255,100,100,0.9);">Access Denied</h1>
        <p class="auth-subtitle">Your Google account isn't on the approved list.</p>
        <a class="auth-google-btn" href="/auth/logout" style="margin-top:1.5rem;background:rgba(255,255,255,0.06);">
            ← Try a different account
        </a>
    </div>
</div>
